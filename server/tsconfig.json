{
    "compilerOptions": {
      "target": "ES2020",
      "module": "NodeNext",
"moduleResolution": "NodeNext",


  
     "outDir": "./dist" ,
      "rootDir": ".",
  
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "typeRoots": ["./types", "./node_modules/@types"],
      "resolveJsonModule": true
    },
    "include": ["server.ts", "lib", "Routes", "controllers","**/*.ts", "types"],
    "exclude": ["dist"],
  }
  